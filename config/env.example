# 环境变量示例（复制为 config/env.local 后填写；项目会自动加载）

# ===== 邮件（Resend）=====
RESEND_API_KEY=re_xxx
RESEND_FROM=AI伴侣 <noreply@ai-girlchat.com>
RESEND_TEST_TO=delivered@resend.dev

# =====（可选）代理：如果你要求全局走 Clash，把端口改成你 Clash 的 HTTP 代理端口（常见 7890）=====
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# =====（可选）数据库：你也可以用环境变量覆盖 config/app.config.json 的 databaseUrl =====
# DATABASE_URL=postgresql://postgres:121212@127.0.0.1:5432/ai_companion

# 复制本文件为 config/env.local，然后填入真实值（该文件会被 .gitignore 忽略）

# --- Database（可选：不填也行，你已在 config/app.config.json 里配 DATABASE_URL） ---
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/ai_companion

# --- Email (Resend) ---
# RESEND_API_KEY=re_xxx
# RESEND_FROM=AI伴侣 <noreply@ai-girlchat.com>

# --- API Key Encryption (L5: encrypt customApiKey/minimaxApiKey at rest) ---
# ENCRYPTION_KEY=your-32-char-or-longer-secret-key-here

# --- Proxy（如需让 Node 走 Clash，把端口改成你 Clash 的 HTTP 端口，常见 7890） ---
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890


